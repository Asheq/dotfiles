#!/bin/sh

if [ -n "$NVIM" ]; then
    # Inside Neovim: open file in the parent instance
	nvim --server "$NVIM" --remote-wait "$@"
	
	# TODO: Add --remote-wait flag so commands like "git commit" work properly.
	# nvim --server "$NVIM" --remote-wait "$@"
else
    # Outside Neovim: just launch normally
    nvim "$@"
fi
